// write "abc" into the memory
mem 0 + 97 .
mem 1 + 98 .
mem 2 + 99 .

// print out the values
1 mem 0 + 1 1 syscall3
1 mem 1 + 1 1 syscall3
1 mem 2 + 1 1 syscall3

// increment each chracter by 1 making it "bcd"
mem 0 + dup , 1 + .
mem 1 + dup , 1 + .
mem 2 + dup , 1 + .

// print out the values
1 mem 0 + 1 1 syscall3
1 mem 1 + 1 1 syscall3
1 mem 2 + 1 1 syscall3